# Maintainer: Anthony (anto22) <https://github.com/anto22>
pkgname=obs-plugin-countdown
pkgver=2.1.1
pkgrel=1
pkgdesc="Countdown timer plugin for OBS Studio"
arch=('x86_64')
url="https://github.com/ashmanix/obs-plugin-countdown"
license=('GPL2')
depends=('obs-studio')
makedepends=('cmake')
source=("https://github.com/ashmanix/obs-plugin-countdown/releases/download/${pkgver}/obs-plugin-countdown-${pkgver}-source.tar.xz")
sha256sums=('7a9231a3dd71980dda8a75cb01f38f3b420c0f79597e1ae6503252aea8770c3a')

build() {
  cd "obs-plugin-countdown-${pkgver}-source"

  cmake -B build -S . \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr

  cmake --build build
}

package() {
  cd "obs-plugin-countdown-${pkgver}-source"

  DESTDIR="${pkgdir}" cmake --install build
}
